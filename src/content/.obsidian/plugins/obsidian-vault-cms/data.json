{
  "projectRoot": "../../",
  "contentRoot": "./",
  "contentTypes": [
    {
      "name": "posts",
      "folder": "posts",
      "template": "posts-template",
      "properties": {
        "title": { "type": "text", "required": true },
        "published": { "type": "date", "required": true },
        "description": { "type": "text", "required": false },
        "image": { "type": "text", "required": false },
        "tags": { "type": "multitext", "required": false },
        "category": { "type": "text", "required": false },
        "draft": { "type": "checkbox", "required": true, "default": false }
      }
    }
  ],
  "astroConfigPath": "../../astro.config.mjs",
  "gitIntegration": true,
  "autoPublish": false,
  "showSetupWizardOnStartup": false,
  "wizardCompleted": true,
  "theme": "default",
  "baseFolder": "../../_bases",
  "homeBaseName": "Home"
}
